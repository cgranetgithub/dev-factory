# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-username

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# DevFactory settings
DEVFACTORY_POLL_INTERVAL=60          # seconds between GitHub polls
DEVFACTORY_DB_PATH=./devfactory.db
DEVFACTORY_WORKSPACE=/tmp/devfactory  # where repos are cloned
DEVFACTORY_MAX_QA_RETRIES=3
DEVFACTORY_LOG_LEVEL=INFO

# Docker
DOCKER_TEST_IMAGE=devfactory-test:latest
